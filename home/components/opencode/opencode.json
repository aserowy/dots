{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "*": "ask",
        "bash": {
            "cargo *": "allow",
            "git *": "allow",
            "grep *": "allow",
            "mkdir *": "allow",
            "openspec *": "allow"
        },
        "doom_loop": "deny",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "question": "allow",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny"
        },
        "todoread": "allow",
        "todowrite": "allow"
    },
    "provider": {
        "github-copilot": {
            "options": {
                "baseURL": "https://api.business.githubcopilot.com"
            }
        },
        "adesso-ai-hub": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Adesso AI Hub LiteLLM",
            "options": {
                "baseURL": "https://adesso-ai-hub.3asabc.de/v1"
            },
            "models": {
                "claude-opus-4-5*": {
                    "name": "claude-opus-4-5*",
                    "limit": {
                        "context": 200000,
                        "output": 65536
                    }
                },
                "claude-opus-4-6*": {
                    "name": "claude-opus-4-6*",
                    "limit": {
                        "context": 200000,
                        "output": 65536
                    }
                }
            }
        }
    },
    "theme": "system"
}
