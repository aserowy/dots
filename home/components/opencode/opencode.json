{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "*": "ask",
        "doom_loop": "deny",
        "edit": "allow",
        "external_directory": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "todoread": "allow",
        "todowrite": "allow"
    },
    "provider": {
        "github-copilot": {
            "options": {
                "baseURL": "https://api.business.githubcopilot.com"
            }
        },
        "adesso-ai-hub": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Adesso AI Hub LiteLLM",
            "options": {
                "baseURL": "https://adesso-ai-hub.3asabc.de/v1"
            },
            "models": {
                "claude-opus-4-5*": {
                    "name": "claude-opus-4-5*",
                    "limit": {
                        "context": 200000,
                        "output": 65536
                    }
                },
                "claude-opus-4-6*": {
                    "name": "claude-opus-4-6*",
                    "limit": {
                        "context": 200000,
                        "output": 65536
                    }
                }
            }
        }
    },
    "plugin": [
        "@mohak34/opencode-notifier@latest",
        "@ex-machina/opencode-anthropic-auth"
    ],
    "theme": "system"
}
